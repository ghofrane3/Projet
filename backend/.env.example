# ====================================
# CONFIGURATION E-COMMERCE BACKEND
# ====================================

# Serveur
PORT=5000
NODE_ENV=development

# Base de données MongoDB
MONGODB_URI=mongodb://localhost:27017/ecommerce

# JWT Access Token (courte durée)
JWT_SECRET=your_jwt_secret_key_here_minimum_64_characters_random_string
JWT_EXPIRES_IN=1h

# JWT Refresh Token (longue durée)
REFRESH_TOKEN_SECRET=your_refresh_token_secret_key_here_minimum_64_characters_random
REFRESH_TOKEN_EXPIRES_IN=7d

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:4200

# Email Configuration
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_16_characters
